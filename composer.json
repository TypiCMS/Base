{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "typicms/base",
    "type": "project",
    "description": "A multilingual CMS built with Laravel",
    "keywords": [
        "cms",
        "multilingual",
        "laravel",
        "typi"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel De Backer",
            "email": "samuel@typidesign.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "bkwld/croppa": "dev-master",
        "eluceo/ical": "^2.14",
        "enshrined/svg-sanitize": "^0.22.0",
        "genealabs/laravel-model-caching": "^13.0.2",
        "laracasts/utilities": "^3.2",
        "laravel/framework": "^13.0",
        "laravel/prompts": "^0.3.5",
        "laravel/tinker": "^3.0",
        "maatwebsite/excel": "^3.1",
        "spatie/eloquent-sortable": "^5.0.0",
        "spatie/laravel-feed": "^4.4",
        "spatie/laravel-markdown-response": "^1.2",
        "spatie/laravel-one-time-passwords": "^1.0",
        "spatie/laravel-passkeys": "dev-main",
        "spatie/laravel-permission": "^7.2.3",
        "spatie/laravel-query-builder": "^7.0.1",
        "symfony/http-client": "^v8.0.7",
        "symfony/mailgun-mailer": "^v8.0.0",
        "typicms/core": "dev-master",
        "typicms/laravel-translatable-bootforms": "dev-master",
        "typicms/nestablecollection": "dev-master",
        "typicms/sidebar": "dev-main",
        "typicms/things": "dev-master",
        "typicms/translatable": "^2.0",
        "typidesign/laravel-artisan-translations": "^4.0",
        "ultrono/laravel-sitemap": "^10.0.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0.5",
        "barryvdh/laravel-ide-helper": "^3.5",
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.4",
        "laravel/boost": "^2.3.1",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "TypiCMS\\Modules\\": "Modules/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi",
            "@php artisan storage:link"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
